<Window x:Class="WitchDrawer.App.Views.DesktopBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Name}"
        Icon="/Assets/app.png"
        SizeToContent="WidthAndHeight"
        MinWidth="180"
        MinHeight="120"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        ShowActivated="False"
        AllowDrop="True"
        Background="Transparent"
        Focusable="True"
        PreviewKeyDown="OnPreviewKeyDown"
        PreviewDrop="OnFilesDropped"
        Drop="OnFilesDropped"
        PreviewDragOver="OnPreviewDragOver"
        PreviewDragLeave="OnPreviewDragLeave">
    <Window.Resources>
        <!-- 精致现代点阵微网格背景 (取代难看的棋盘像素格子) -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,18,18" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1A888888">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="9,9" RadiusX="1.2" RadiusY="1.2" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 虚线滚动跑马灯动画 -->
        <Storyboard x:Key="ScrollDashes" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="DashRect"
                             Storyboard.TargetProperty="StrokeDashOffset"
                             From="0" To="7" Duration="0:0:0.6" />
        </Storyboard>

        <Style x:Key="MappingModeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder"
            Margin="6">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource GlassSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource GlassStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.22" ShadowDepth="2" Direction="270" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Type}" Value="Pixel">
                        <Setter Property="CornerRadius" Value="14" />
                        <Setter Property="TextElement.FontFamily" Value="Consolas, Courier New, 微软雅黑" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource GlassSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource GlassStrokeBrush}" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.26" ShadowDepth="1" Direction="270" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <Grid MouseLeftButtonDown="OnSurfaceMouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 像素模式专用精致主题自适应微网格图层 -->
            <Rectangle Grid.RowSpan="2" Panel.ZIndex="-1" IsHitTestVisible="False">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Fill" Value="Transparent" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Type}" Value="Pixel">
                                <Setter Property="Fill" Value="{StaticResource DotGridBrush}" />
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- 顶部标题栏与 macOS 关闭小红点 -->
            <Grid Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- 关闭小按钮 (悬浮变亮红，自带微过渡，像素模式下自动方块化) -->
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="56,0,86,0">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,34,0">
                    <StackPanel.Style>
                        <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMappingBox}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Command="{Binding UseMappingGridModeCommand}"
                            ToolTip="网格视图"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MappingModeButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGridMode}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M 2,2 L 7,2 L 7,7 L 2,7 Z M 10,2 L 15,2 L 15,7 L 10,7 Z M 2,10 L 7,10 L 7,15 L 2,15 Z M 10,10 L 15,10 L 15,15 L 10,15 Z"
                              Stroke="{DynamicResource TextMutedBrush}"
                              StrokeThickness="1.4"
                              Width="16"
                              Height="16"
                              Stretch="Uniform" />
                    </Button>
                    <Button Command="{Binding UseMappingListModeCommand}"
                            ToolTip="列表视图">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MappingModeButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M 3,4 L 15,4 M 3,8 L 15,8 M 3,12 L 15,12"
                              Stroke="{DynamicResource TextMutedBrush}"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16"
                              Height="16"
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>

                <Button Click="OnCloseClick"
                        Width="12"
                        Height="12"
                        Margin="0,0,14,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Rectangle x:Name="Circle" Fill="#20808080" Width="12" Height="12" RadiusX="6" RadiusY="6" SnapsToDevicePixels="True" />
                                <Path x:Name="Cross" Data="M 3.5,3.5 L 8.5,8.5 M 8.5,3.5 L 3.5,8.5" 
                                      Stroke="White" StrokeThickness="1.2" Opacity="0" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Circle" Property="Fill" Value="#FF5F56" />
                                    <Setter TargetName="Cross" Property="Opacity" Value="0.9" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 主内容区: ListBox -->
            <ListBox x:Name="IconList"
                     Grid.Row="1"
                     Panel.ZIndex="1"
                     Margin="6,0,6,6"
                     Padding="2"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     BorderThickness="0"
                     Background="Transparent"
                     Focusable="True"
                     FocusVisualStyle="{x:Null}"
                     ItemsSource="{Binding Items}"
                     SelectionMode="Single"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     SelectionChanged="OnItemsSelectionChanged"
                     PreviewMouseLeftButtonDown="OnIconPreviewMouseLeftButtonDown"
                     MouseMove="OnIconMouseMove"
                     MouseDoubleClick="OnItemsMouseDoubleClick">
                <ListBox.Style>
                    <Style TargetType="{x:Type ListBox}" BasedOn="{StaticResource {x:Type ListBox}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas IsItemsHost="True" 
                                Width="{Binding DataContext.GridCanvasWidth, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                Height="{Binding DataContext.GridCanvasHeight, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Canvas.Left" Value="{Binding GridLeft}" />
                        <Setter Property="Canvas.Top" Value="{Binding GridTop}" />
                        <Setter Property="Width" Value="{Binding DataContext.LayoutSettings.ItemSlotWidth, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                        <Setter Property="Height" Value="{Binding DataContext.LayoutSettings.ItemSlotHeight, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                        <Setter Property="Padding" Value="{Binding DataContext.LayoutSettings.ItemPadding, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1.2"
                                            Margin="{Binding DataContext.LayoutSettings.ItemMargin, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                            Padding="{TemplateBinding Padding}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="{Binding DataContext.LayoutSettings.ItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.Type, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="Pixel">
                                                        <Setter Property="CornerRadius" Value="6" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter x:Name="ItemContent" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Normal hover (with scale animation) -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                <Condition Binding="{Binding DataContext.Type, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="Normal" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.1" />
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>

                                        <!-- Mapping hover (with scale animation) -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                <Condition Binding="{Binding DataContext.Type, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="Mapping" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.1" />
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>

                                        <!-- Pixel hover (instant background change, no animation) -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                <Condition Binding="{Binding DataContext.Type, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="Pixel" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                        </MultiDataTrigger>

                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsDragSource}" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="Transparent" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                            <Setter TargetName="ItemContent" Property="Opacity" Value="0.38" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ToolTip="{Binding PathLabel}">
                            <!-- 图标卡片背景 -->
                            <Border x:Name="IconBorder"
                                    Width="{Binding DataContext.LayoutSettings.IconFrameSize, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    Height="{Binding DataContext.LayoutSettings.IconFrameSize, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CornerRadius="{Binding DataContext.LayoutSettings.IconCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    Background="{DynamicResource GlassInnerBrush}"
                                    BorderBrush="{DynamicResource GlassStrokeBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <Grid>
                                    <Image x:Name="IconImage"
                                           Width="{Binding DataContext.LayoutSettings.IconSize, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                           Height="{Binding DataContext.LayoutSettings.IconSize, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Source="{Binding IconImage}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    
                                    <TextBlock Text="{Binding FallbackIconText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding DataContext.LayoutSettings.FallbackIconFontSize, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Visibility="{Binding HasIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.Type, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="Pixel">
                                <Setter TargetName="IconBorder" Property="CornerRadius" Value="4" />
                                <Setter TargetName="IconImage" Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox x:Name="FileList"
                     Grid.Row="1"
                     Panel.ZIndex="1"
                     Width="310"
                     MinHeight="118"
                     MaxHeight="520"
                     Margin="0,2,0,8"
                     Padding="7,4"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     BorderThickness="0"
                     Background="Transparent"
                     Focusable="True"
                     FocusVisualStyle="{x:Null}"
                     ItemsSource="{Binding Items}"
                     SelectionMode="Single"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     SelectionChanged="OnItemsSelectionChanged"
                     PreviewMouseLeftButtonDown="OnIconPreviewMouseLeftButtonDown"
                     MouseMove="OnIconMouseMove"
                     MouseDoubleClick="OnItemsMouseDoubleClick">
                <ListBox.Style>
                    <Style TargetType="{x:Type ListBox}" BasedOn="{StaticResource {x:Type ListBox}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMappingListMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Height" Value="32" />
                        <Setter Property="Padding" Value="2,3" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ToolTip="{Binding PathLabel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="22"
                                  Height="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Image Source="{Binding IconImage}"
                                       Width="20"
                                       Height="20"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        CornerRadius="2"
                                        Padding="2,1"
                                        Visibility="{Binding HasIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding FallbackIconText}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="7.5"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Canvas Grid.Row="1"
                    Panel.ZIndex="2"
                    Margin="8,2,8,8"
                    IsHitTestVisible="False"
                    ClipToBounds="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="{Binding GridCanvasWidth}"
                    Height="{Binding GridCanvasHeight}"
                    Visibility="{Binding IsDragPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Rectangle Canvas.Left="{Binding DragPreviewLeft}"
                           Canvas.Top="{Binding DragPreviewTop}"
                           Width="{Binding DragPreviewWidth}"
                           Height="{Binding DragPreviewHeight}"
                           Fill="{DynamicResource AccentSoftBrush}"
                           Stroke="{DynamicResource AccentBrush}"
                           StrokeThickness="1.4"
                           StrokeDashArray="4 3"
                           Opacity="0.68"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="RadiusX" Value="{Binding LayoutSettings.ItemCornerRadius.TopLeft}" />
                            <Setter Property="RadiusY" Value="{Binding LayoutSettings.ItemCornerRadius.TopLeft}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="Pixel">
                                    <Setter Property="RadiusX" Value="6" />
                                    <Setter Property="RadiusY" Value="6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
            </Canvas>

            <!-- 空列表时: 拖拽投放槽 (跑马灯虚线动画) -->
            <Border Grid.Row="1"
                    Panel.ZIndex="0"
                    Margin="14"
                    Background="Transparent"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
                        <Style.Triggers>
                            <!-- 拖拽滑入时，卡片背景高亮，启动跑马灯 -->
                            <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <!-- 流动虚线框 -->
                    <Rectangle x:Name="DashRect" 
                               Stroke="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                               StrokeThickness="1.5"
                               StrokeDashArray="4 3">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="RadiusX" Value="16" />
                                <Setter Property="RadiusY" Value="16" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="Pixel">
                                        <Setter Property="RadiusX" Value="6" />
                                        <Setter Property="RadiusY" Value="6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>
                    
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                        <!-- 下载/拖入 Path 箭头 -->
                        <Path x:Name="ArrowPath"
                              Data="M 6,1 L 6,11 M 2,7 L 6,11 L 10,7 M 1,14 L 11,14" 
                              Stroke="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}" 
                              StrokeThickness="1.8" 
                              Width="12" Height="14" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,8" 
                              SnapsToDevicePixels="True">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="StrokeStartLineCap" Value="Round" />
                                    <Setter Property="StrokeEndLineCap" Value="Round" />
                                </Style>
                            </Path.Style>
                        </Path>
                        
                        <TextBlock x:Name="TitleText"
                                   Text="拖入文件至此"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
