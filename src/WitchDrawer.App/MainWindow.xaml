<Window x:Class="WitchDrawer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WitchDrawer"
        Width="1120"
        Height="700"
        MinWidth="920"
        MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowDrop="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Drop="OnFilesDropped"
        PreviewDragOver="OnPreviewDragOver">
    <Border Margin="10"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="OnShellHeaderMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="7" Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="W"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="WitchDrawer"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Background="{DynamicResource PanelAltBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5"
                            Margin="0,0,8,0">
                        <TextBlock Text="Ctrl+Alt+W"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" />
                    </Border>
                    <Button Width="34"
                            Height="28"
                            Padding="0"
                            Content="_"
                            Click="OnMinimizeClicked"
                            ToolTip="最小化" />
                    <Button Width="34"
                            Height="28"
                            Padding="0"
                            Content="X"
                            Margin="6,0,0,0"
                            Click="OnCloseClicked"
                            ToolTip="关闭" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="252" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource PanelAltBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="0,1,1,0"
                        CornerRadius="0,0,0,24"
                        Padding="18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Button Content="概览"
                                        Command="{Binding ShowDashboardCommand}"
                                        Margin="0,0,8,0" />
                                <Button Content="设置"
                                        Command="{Binding ShowSettingsCommand}" />
                            </StackPanel>

                            <TextBlock Text="收纳盒"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="6,0,0,10" />

                            <ListBox ItemsSource="{Binding Boxes}"
                                     SelectedItem="{Binding SelectedBox, Mode=TwoWay}"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding StorageLabel}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26"
                                                    Height="26"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource AccentSoftBrush}">
                                                <TextBlock Text="{Binding Badge}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom">
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding CreateNormalBoxCommand}"
                                    Content="新建普通收纳盒"
                                    Margin="0,0,0,10" />
                            <Button Command="{Binding CreateMappingBoxCommand}"
                                    Content="新建映射收纳盒" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1" Margin="28,24,28,24">
                    <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Overview"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedBox.Name, TargetNullValue=选择一个收纳盒}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12,8"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Boxes.Count, StringFormat={}{0} 个收纳盒}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </Border>
                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12,8">
                                    <TextBlock Text="{Binding Items.Count, StringFormat={}{0} 个文件}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="{DynamicResource AccentBrush}"
                                        CornerRadius="20"
                                        Padding="20"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="桌面收纳栏"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.9" />
                                        <TextBlock Text="{Binding Boxes.Count}"
                                                   Foreground="White"
                                                   FontSize="40"
                                                   FontWeight="SemiBold"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="所有收纳盒已同步到桌面"
                                                   Foreground="White"
                                                   Opacity="0.82"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="当前模式"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedBox.TypeLabel}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedBox.Description}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <Button Content="&#x5220;&#x9664;&#x6536;&#x7eb3;&#x76d2;"
                                                Command="{Binding DeleteSelectedBoxCommand}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource DropZoneBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="投放区"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="拖入当前收纳盒"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="也可以拖到桌面上的对应收纳栏。"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="16">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="4,2,4,14">
                                        <TextBlock Text="文件"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Items.Count, StringFormat={}{0} 项}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </Grid>

                                    <ListBox x:Name="MainItemsList"
                                             ItemsSource="{Binding Items}"
                                             PreviewKeyDown="OnMainItemsPreviewKeyDown"
                                             MouseDoubleClick="OnItemsMouseDoubleClick"
                                             ScrollViewer.CanContentScroll="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="11"
                                                            Background="{DynamicResource AccentSoftBrush}">
                                                        <Grid>
                                                            <Image Source="{Binding IconImage}"
                                                                   Width="23"
                                                                   Height="23"
                                                                   Stretch="Uniform"
                                                                   Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <TextBlock Text="{Binding FallbackIconText}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       Visibility="{Binding HasIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ShortPathLabel}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="打开"
                                                                Margin="0,0,8,0"
                                                                Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="移除"
                                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="Settings"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="设置"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Width="520" HorizontalAlignment="Left">
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="外观"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding ThemeLabel, StringFormat=当前风格：{0}}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                    <UniformGrid Grid.Column="1" Columns="2" VerticalAlignment="Center">
                                        <Button Content="清透"
                                                Command="{Binding ApplyMoeThemeCommand}"
                                                Margin="0,0,8,0" />
                                        <Button Content="毛玻璃"
                                                Command="{Binding ApplyGlassThemeCommand}" />
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="快速面板"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="快捷键：Ctrl+Alt+W"
                                               Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="桌面收纳栏"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="桌面栏仅显示投放区和文件图标；标题、刷新、状态信息已移入主窗口。"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
